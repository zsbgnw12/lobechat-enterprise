# Enterprise Gateway — environment variables
# Copy to .env and fill in real values.

# Server
API_PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Auth
AUTH_MODE=dev        # dev | casdoor
CORS_ORIGINS=http://localhost:3000

# Mock mode (use real upstreams when false)
MOCK_MODE=true

# Redis (optional — BullMQ audit queue + rate-limit store)
# REDIS_URL=redis://localhost:6379

# Rate limiting
# Set to true only for acceptance/load test runs that must bypass limits.
RATE_LIMIT_DISABLED=false

# Casdoor (required when AUTH_MODE=casdoor)
# CASDOOR_URL=
# CASDOOR_CLIENT_ID=
# CASDOOR_ROLE_MAP=
# CASDOOR_JWKS_URL=
# CASDOOR_ISSUER=
# CASDOOR_AUDIENCE=

# Upstream APIs
# GONGDAN_API_URL=
# GONGDAN_API_KEY=
# SUPER_OPS_API_URL=
# SUPER_OPS_API_KEY=
# CLOUDCOST_API_URL=
# CLOUDCOST_BEARER=
# KB_AGENT_URL=
# KB_API_KEY=
# AI_SEARCH_URL=
# AI_SEARCH_KEY=
# SANDBOX_URL=
# SANDBOX_KEY=
# DOC_AGENT_URL=
# DOC_AGENT_KEY=
# CLOUDCOST_M2M_CLIENT_ID=
# CLOUDCOST_M2M_CLIENT_SECRET=
# CLOUDCOST_M2M_SCOPE=
