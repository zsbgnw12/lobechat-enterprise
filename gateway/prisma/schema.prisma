generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model EnterpriseUser {
  id           String   @id @default(uuid())
  casdoorSub   String?  @unique @map("casdoor_sub")
  username     String   @unique
  displayName  String   @map("display_name")
  email        String?
  departmentId String?  @map("department_id")
  region       String?
  metadata     Json?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  userRoles EnterpriseUserRole[]

  @@map("enterprise_users")
}

model EnterpriseRole {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  userRoles EnterpriseUserRole[]

  @@map("enterprise_roles")
}

model EnterpriseUserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  grantedBy String?  @map("granted_by")
  grantedAt DateTime @default(now()) @map("granted_at")

  user EnterpriseUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role EnterpriseRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("enterprise_user_roles")
}

model EnterpriseToolRegistry {
  id          String   @id @default(uuid())
  key         String   @unique
  category    String
  displayName String   @map("display_name")
  description String?
  inputSchema Json?    @map("input_schema")
  isEnabled   Boolean  @default(true) @map("is_enabled")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("enterprise_tool_registry")
}

model EnterpriseToolPermission {
  id          String   @id @default(uuid())
  subjectType String   @map("subject_type") // role|user
  subjectId   String   @map("subject_id")
  toolId      String   @map("tool_id")
  allow       Boolean  @default(true)
  constraints Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([subjectType, subjectId])
  @@index([toolId])
  @@map("enterprise_tool_permissions")
}

model EnterpriseDataScope {
  id           String   @id @default(uuid())
  subjectType  String   @map("subject_type")
  subjectId    String   @map("subject_id")
  sourceSystem String   @map("source_system")
  entityType   String   @map("entity_type")
  scope        Json
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([subjectType, subjectId])
  @@index([sourceSystem, entityType])
  @@map("enterprise_data_scopes")
}

model EnterpriseFieldPolicy {
  id           String   @id @default(uuid())
  sourceSystem String   @map("source_system")
  entityType   String   @map("entity_type")
  fieldPath    String   @map("field_path")
  policy       String // drop|mask|hash
  roleKeys     String[] @map("role_keys")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([sourceSystem, entityType])
  @@map("enterprise_field_policies")
}

model EnterpriseIdentityMap {
  id              String   @id @default(uuid())
  sourceSystem    String   @map("source_system")
  entityType      String   @map("entity_type")
  sourceEntityId  String   @map("source_entity_id")
  tenantId        String?  @map("tenant_id")
  customerId      String?  @map("customer_id")
  ownerUserId     String?  @map("owner_user_id")
  departmentId    String?  @map("department_id")
  salesUserId     String?  @map("sales_user_id")
  operationUserId String?  @map("operation_user_id")
  region          String?
  visibilityLevel String?  @map("visibility_level")
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([sourceSystem, entityType, sourceEntityId])
  @@map("enterprise_identity_map")
}

model EnterpriseAuditLog {
  id               String   @id @default(uuid())
  at               DateTime @default(now())
  userId           String?  @map("user_id")
  username         String?
  toolKey          String?  @map("tool_key")
  action           String // call|filter|mask|deny|missing_identity_map
  request          Json?
  responseSummary  Json?    @map("response_summary")
  outcome          String // ok|denied|error
  meta             Json?

  @@index([userId])
  @@index([toolKey])
  @@index([outcome])
  @@index([at])
  @@map("enterprise_audit_logs")
}
